# Credenciais do banco (usadas pelo Docker Compose e pelo go run local)
DB_USER=taskflow
DB_PASSWORD=taskflow
DB_NAME=taskflow

# URL para rodar fora do Docker (go run ./cmd/server ou go run ./cmd/seed)
DATABASE_URL=postgres://taskflow:taskflow@localhost:5432/taskflow?sslmode=disable

# Em produção, use uma string aleatória longa (ex: openssl rand -hex 32). Nunca commite o valor real.
SESSION_SECRET=troque-esta-chave-em-producao

PORT=3000
GIN_MODE=debug
